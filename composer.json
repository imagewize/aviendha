{
	"name": "imagewize/aviendha",
	"description": "A lean WooCommerce block theme by Jasper Frumau",
	"type": "wordpress-theme",
	"license": "GPL-3.0-or-later",
	"authors": [
		{
			"name": "Jasper Frumau",
			"email": "jasper@imagewize.com"
		}
	],
	"require": {
		"php": ">=8.0"
	},
	"require-dev": {
		"php-parallel-lint/php-parallel-lint": "^1.3",
		"wp-coding-standards/wpcs": "^3.0.0",
		"phpcompatibility/phpcompatibility-wp": "^2.1"
	},
	"scripts": {
		"lint": "@php ./vendor/bin/parallel-lint --exclude .git --exclude vendor .",
		"wpcs:scan": "@php ./vendor/squizlabs/php_codesniffer/bin/phpcs --ignore=*/vendor/*,*/node_modules/* --standard=WordPress .",
		"wpcs:fix": "@php ./vendor/squizlabs/php_codesniffer/bin/phpcbf --ignore=*/vendor/*,*/node_modules/* --standard=WordPress ."
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
