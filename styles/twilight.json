{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"title": "Twilight",
	"version": 3,
	"settings": {
		"color": {
			"palette": [
				{ "name": "Base", "slug": "base", "color": "#211C1A" },
				{ "name": "Tertiary", "slug": "tertiary", "color": "#2B2422" },
				{ "name": "Border Light", "slug": "border-light", "color": "#3D3532" },
				{ "name": "Contrast", "slug": "contrast", "color": "#FAF7F2" },
				{ "name": "Main", "slug": "main", "color": "#FDA4AF" },
				{ "name": "Primary", "slug": "primary", "color": "#FB7185" },
				{ "name": "Accent", "slug": "accent", "color": "#84CC16" },
				{ "name": "Secondary", "slug": "secondary", "color": "#C9C0B8" },
				{ "name": "Main Accent", "slug": "main-accent", "color": "#A8A29E" },
				{ "name": "Primary Accent", "slug": "primary-accent", "color": "#3B1F28" },
				{ "name": "Primary Alt", "slug": "primary-alt", "color": "#F43F5E" },
				{ "name": "White", "slug": "white", "color": "#FFFFFF" },
				{ "name": "Terracotta", "slug": "terracotta", "color": "#FB923C" },
				{ "name": "Sand Deep", "slug": "sand-deep", "color": "#3D3532" }
			],
			"gradients": [
				{
					"name": "Rose Bloom",
					"slug": "rose-bloom",
					"gradient": "linear-gradient(135deg, #FB7185 0%, #2B1A20 100%)"
				},
				{
					"name": "Sunset",
					"slug": "sunset",
					"gradient": "linear-gradient(135deg, #FB923C 0%, #FB7185 100%)"
				},
				{
					"name": "Sand",
					"slug": "sand",
					"gradient": "linear-gradient(180deg, #211C1A 0%, #2B2422 100%)"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"elements": {
			"button": {
				"color": {
					"text": "var(--wp--preset--color--base)",
					"background": "var(--wp--preset--color--primary)"
				}
			}
		}
	}
}
